# Application
APP_HOSTNAME=hmlapi-modelo.pmvc.ba.gov.br
NODE_ENV=development
APP_VERSION=1.0.0
HTTP_PORT=3006

# Elasticsearch
ELASTICSEARCH=http://192.168.10.121:9200
APP_NAME=servihub-backend-vini
ELASTICSEARCH_ACTIVE=false

# Authentication
JWT_SECRET=modelo-back-end
JWT_EXPIRE=86400s
KEYCLOAK_URL=https://seu-keycloak
KEYCLOAK_REALM=seu-realm
KEYCLOAK_CLIENT_ID=seu-client-publico
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASS=admin

# DataBase
DATABASE_URL="postgres://username:password@host:port/database?schema=public"

# Security
SSL=false
